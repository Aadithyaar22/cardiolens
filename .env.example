# --- MongoDB Atlas ---
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
CARDIOLENS_DB=cardiolens

# --- Azure ML workspace ---
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=
AZURE_WORKSPACE_NAME=
AZURE_ENDPOINT_NAME=cardiolens-endpoint
AZURE_ENDPOINT_KEY=

# --- Azure Blob Storage (for model artifact) ---
AZURE_BLOB_CONNECTION_STRING=
MODEL_BLOB_CONTAINER=cardiolens-models
MODEL_BLOB_NAME=champion_model.joblib

# --- Model versioning ---
MODEL_VERSION=cardiolens-v0.1
